#!/bin/bash
# Adds <Mount Point> to a specified LXC container

set -euo pipefail

CTID="${1:-}"
MOUNTPOINT="${2:-}"
MOUNTPOINT_LOCAL="${3:-}"

# If MOUNTPOINT_LOCAL is empty, use host MOUNTPOINT
MOUNTPOINT_LOCAL="${MOUNTPOINT_LOCAL:-$MOUNTPOINT}"

# --- functions ---
error_exit() {
    echo "Error: $1" >&2
    exit 1
}

# --- checks ---
if [[ -z "$CTID" ]]; then
    error_exit "Usage: $0 <Container ID> <Mount Point> <Local Mount Point>"
fi

if ! pct status "$CTID" &>/dev/null; then
    error_exit "Container $CTID does not exist."
fi

if pct config "$CTID" | grep '^mp[0-9]\+:' | sed -n 's/.*mp=\([^,]*\).*/\1/p' | grep -Fxq "$MOUNTPOINT_LOCAL"; then
    echo "Container path already mounted."
fi

# --- create container mount path ---
pct exec "$CTID" -- mkdir -p "$MOUNTPOINT_LOCAL" || error_exit "Failed to create mount path inside container."

# --- setting permissions ---
chown -R 100000:100000 "$MOUNTPOINT"
chmod -R 777 "$MOUNTPOINT"

pct exec "$CTID" -- chown -R :users "$MOUNTPOINT_LOCAL"
pct exec "$CTID" -- chmod -R 777 "$MOUNTPOINT_LOCAL"

# --- find next free mp index ---
NEXT_MP=$(pct config "$CTID" | grep -oE '^mp[0-9]+' | sed 's/mp//' | sort -n | tail -1 || true)

if [[ -z "$NEXT_MP" ]]; then
    NEXT_MP=0
else
    NEXT_MP=$((NEXT_MP + 1))
fi

# --- add mount ---
echo "Adding mount as mp${NEXT_MP} to container $CTID..."
pct set "$CTID" -mp${NEXT_MP} "${MOUNTPOINT},mp=${MOUNTPOINT_LOCAL}" || error_exit "Failed to add mount."

echo "Mount path added successfully to container $CTID."
