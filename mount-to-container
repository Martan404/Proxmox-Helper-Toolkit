#!/bin/bash
# Adds <Mount Point> to a specified LXC container

set -euo pipefail

CTID="${1:-}"
MOUNTPOINT="${2:-}"
MOUNTPOINT_LOCAL="${3:-}"

# If MOUNTPOINT_LOCAL is empty, use MOUNTPOINT
MOUNTPOINT_LOCAL="${MOUNTPOINT_LOCAL:-$MOUNTPOINT}"

# --- functions ---
error_exit() {
    echo "Error: $1" >&2
    exit 1
}

# --- checks ---
if [[ -z "$CTID" ]]; then
    error_exit "Usage: $0 <Container ID> <Mount Point> <Local Mount Point>"
fi

if ! pct status "$CTID" &>/dev/null; then
    error_exit "Container $CTID does not exist."
fi

# --- create container mount path ---
if [[ ! -e "$MOUNTPOINT_LOCAL" ]]; then
    pct exec "$CTID" -- mkdir -p "$MOUNTPOINT_LOCAL" || error_exit "Failed to create mount path inside container."
fi

# --- setting permissions ---
pct exec "$CTID" -- chown -R nobody:nogroup "$MOUNTPOINT_LOCAL"

# --- add mount ---
echo "Adding mount path to container $CTID..."
pct set "$CTID" -mp0 "${MOUNTPOINT},mp=${MOUNTPOINT_LOCAL}" || error_exit "Failed to add mount."

echo "Mount path added successfully to container $CTID."