#!/usr/bin/env bash

set -euo pipefail

TARGET_DIR="/usr/local/bin"
REPO_API="https://api.github.com/repos/Martan404/Proxmox-Helper-Toolkit/contents"
BRANCH="main"

echo "Updating Proxmox Helper Toolkit scripts..."

# Get list of files in the repo root
files=$(curl -fsSL "$REPO_API?ref=$BRANCH" | grep -oP '"name":\s*"\K[^"]+')

for file in $files; do
    # Skip LICENSE
    if [ "$file" = "LICENSE" ]; then
        continue
    fi

    echo "Installing $file..."
    curl -fsSL "https://raw.githubusercontent.com/Martan404/Proxmox-Helper-Toolkit/$BRANCH/$file" -o "$TARGET_DIR/$file"
    chmod +x "$TARGET_DIR/$file"
done

echo "Done! All scripts are updated"