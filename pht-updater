#!/usr/bin/env bash
# Install and update Proxmox Helper Toolkit

TARGET_DIR="/usr/local/bin"
TRACK_FILE="$TARGET_DIR/.pht_scripts"
REPO="Martan404/Proxmox-Helper-Toolkit"
BRANCH="main"
shopt -s dotglob # Allow dotfiles to be included in wildcard

echo "Updating Proxmox Helper Toolkit scripts..."

# Create a temporary directory and delete on exit
TEMP_DIR=$(mktemp -d)
trap 'rm -rf "$TEMP_DIR"' EXIT

# Ensure tracking file exists
touch "$TRACK_FILE"

# Get list of files in the repo root
files=$(curl -fsSL -H "Cache-Control: no-cache" "https://api.github.com/repos/$REPO/contents?ref=$BRANCH" | grep -oP '"name":\s*"\K[^"]+')

new_files=()
updated_files=()
removed_files=()
scripts_to_keep=()

for file in $files; do
    # Skip non-script files
    case "$file" in
        LICENSE|.gitignore|README.md)
            continue
            ;;
    esac

    echo "Downloading $file..."
    curl -fsSL -H "Cache-Control: no-cache" "https://raw.githubusercontent.com/$REPO/$BRANCH/$file?cb=$(date +%s)" -o "$TEMP_DIR/$file"
    chmod +x "$TEMP_DIR/$file"

    case "$file" in
        *.pht|.bash-tui-toolkit.bash)
            ;;
        *)
            scripts_to_keep+=("$file") # Track downloaded scripts
            ;;
    esac

    # Check if the file already exists and is different
    if [ -f "$TARGET_DIR/$file" ]; then
        if ! cmp -s "$TEMP_DIR/$file" "$TARGET_DIR/$file"; then
            updated_files+=("$file")
        fi
    else
        # New file
        new_files+=("$file")
    fi
done

# Move files from temp directory to target
echo "Moving downloaded files to $TARGET_DIR"

for file in "$TEMP_DIR"/*; do
    mv -f "$file" "$TARGET_DIR/"
done

# Read currently tracked scripts
mapfile -t tracked_scripts < "$TRACK_FILE"

# Check for old scripts and remove them, also remove .pht if available
for old_file in "${tracked_scripts[@]}"; do

    if [[ ! " ${scripts_to_keep[*]} " == *"$old_file"* ]]; then
        if [ -f "$TARGET_DIR/$old_file" ]; then

            removed_files+=("$old_file")
            rm -f "$TARGET_DIR/$old_file"
            rm -f "$TARGET_DIR/$old_file.pht"
        fi
    fi
done

# Update tracking file
printf "%s\n" "${scripts_to_keep[@]}" > "$TRACK_FILE"

# Report removed files
if [ "${#removed_files[@]}" -gt 0 ]; then
    echo "The following files got removed:"
    for script in "${removed_files[@]}"; do
        echo "  - $script"
    done
fi

# Report new files
if [ "${#new_files[@]}" -gt 0 ]; then
    echo "The following files were newly installed:"
    for script in "${new_files[@]}"; do
        echo "  - $script"
    done
fi

# Report updated files
if [ "${#updated_files[@]}" -gt 0 ]; then
    echo "The following files were updated:"
    for script in "${updated_files[@]}"; do
        echo "  - $script"
    done
else
    echo "All files are already up-to-date"
fi

echo "Done! All files are updated"
