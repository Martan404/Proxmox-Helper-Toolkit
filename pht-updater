#!/usr/bin/env bash

set -euo pipefail

TARGET_DIR="/usr/local/bin"
REPO="Martan404/Proxmox-Helper-Toolkit"
BRANCH="main"

echo "Updating Proxmox Helper Toolkit scripts..."

# Get list of files in the repo root
files=$(curl -fsSL -H "Cache-Control: no-cache" "https://api.github.com/repos/$REPO/contents?ref=$BRANCH" | grep -oP '"name":\s*"\K[^"]+')

for file in $files; do
    # Skip non-script files
    case "$file" in
    LICENSE|.gitignore|README.md)
        continue
        ;;
    esac

    echo "Installing $file..."
    curl -fsSL -H "Cache-Control: no-cache" "https://raw.githubusercontent.com/$REPO/$BRANCH/$file" -o "$TARGET_DIR/$file"
    chmod +x "$TARGET_DIR/$file"
done

echo "Done! All scripts are updated"