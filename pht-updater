#!/usr/bin/env bash
# Install and update Proxmox Helper Toolkit

TARGET_DIR="/usr/local/bin"
PHT_DIR="$TARGET_DIR/pht-files"
TRACK_FILE="$TARGET_DIR/.pht_scripts"

REPO="Martan404/Proxmox-Helper-Toolkit"
BRANCH="main"

declare -A repo_files
declare -A file_status
declare -A scripts_to_track

echo "Updating Proxmox Helper Toolkit scripts..."

TEMP_DIR=$(mktemp -d)
trap 'rm -rf "$TEMP_DIR"' EXIT

mkdir -p "$PHT_DIR"

touch "$TRACK_FILE"

# Get repository files
files=$(curl -fsSL "https://api.github.com/repos/$REPO/git/trees/$BRANCH?recursive=1" | grep -B2 '"type": "blob"' | grep -oP '"path":\s*"\K[^"]+')

for file in $files; do

    case "$file" in
        LICENSE|README.md|.gitignore)
            continue
            ;;
    esac

    echo "Downloading $file..."

    mkdir -p "$TEMP_DIR/$(dirname "$file")"

    curl -fsSL "https://raw.githubusercontent.com/$REPO/$BRANCH/$file?nc=$(date +%s)" -o "$TEMP_DIR/$file"

    repo_files["$file"]=1

    # Track only root executables
    if [[ "$file" != */* ]]; then

        case "$file" in
            *.pht|*.bash)
                ;;
            *)
                chmod +x "$TEMP_DIR/$file"
                scripts_to_track["$file"]=1
                ;;
        esac

    fi

    # Check status
    if [[ -f "$TARGET_DIR/$file" ]]; then

        if ! cmp -s "$TEMP_DIR/$file" "$TARGET_DIR/$file"; then
            file_status["$file"]="updated"
        fi

    else

        file_status["$file"]="new"

    fi

done

# Build list of locally installed files we own
declare -A installed_files

# Root scripts
while IFS= read -r script; do

    [[ -n "$script" ]] &&
        installed_files["$script"]=1

done < "$TRACK_FILE"

# pht-files contents
if [[ -d "$PHT_DIR" ]]; then

    while IFS= read -r file; do

        relative="pht-files/$(basename "$file")"

        installed_files["$relative"]=1

    done < <(find "$PHT_DIR" -maxdepth 1 -type f)

fi

# Find removed files
for old_file in "${!installed_files[@]}"; do

    if [[ -z "${repo_files[$old_file]}" ]]; then

        # Ignore directories
        [[ -d "$TARGET_DIR/$old_file" ]] && continue

        file_status["$old_file"]="removed"

        rm -f "$TARGET_DIR/$old_file"

    fi

done

# Install/update files
echo "Installing files..."

cp -a "$TEMP_DIR/." "$TARGET_DIR/"

# Update root script tracker
printf "%s\n" "${!scripts_to_track[@]}" | sort > "$TRACK_FILE"

# Build reports
new_files=()
updated_files=()
removed_files=()

for file in "${!file_status[@]}"; do

    case "${file_status[$file]}" in

        new)
            new_files+=("$file")
            ;;

        updated)
            updated_files+=("$file")
            ;;

        removed)
            removed_files+=("$file")
            ;;

    esac

done

# Sort reports
if [[ ${#new_files[@]} -gt 0 ]]; then
    mapfile -t new_files < <(printf "%s\n" "${new_files[@]}" | sort)
fi

if [[ ${#updated_files[@]} -gt 0 ]]; then
    mapfile -t updated_files < <(printf "%s\n" "${updated_files[@]}" | sort)
fi

if [[ ${#removed_files[@]} -gt 0 ]]; then
    mapfile -t removed_files < <(printf "%s\n" "${removed_files[@]}" | sort)
fi

# Report removed
if [[ ${#removed_files[@]} -gt 0 ]]; then

    echo
    echo "The following files were removed:"

    for file in "${removed_files[@]}"; do
        echo "  - $file"
    done

fi

# Report new
if [[ ${#new_files[@]} -gt 0 ]]; then

    echo
    echo "The following files were newly installed:"

    for file in "${new_files[@]}"; do
        echo "  - $file"
    done

fi

# Report updated
if [[ ${#updated_files[@]} -gt 0 ]]; then

    echo
    echo "The following files were updated:"

    for file in "${updated_files[@]}"; do
        echo "  - $file"
    done

fi

if [[ ${#new_files[@]} -eq 0 &&
      ${#updated_files[@]} -eq 0 &&
      ${#removed_files[@]} -eq 0 ]]; then

    echo "All files are already up-to-date"

fi

echo
echo "Done! All files are updated"
