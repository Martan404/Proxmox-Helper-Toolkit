#!/usr/bin/env bash
# Install and update Proxmox Helper Toolkit

TARGET_DIR="/usr/local/bin"
PHT_DIR="$TARGET_DIR/pht-files"
TRACK_FILE="$TARGET_DIR/.pht_scripts"
REPO="Martan404/Proxmox-Helper-Toolkit"
BRANCH="main"

declare -A file_status
declare -A scripts_to_track
shopt -s dotglob # Allow dotfiles to be included in wildcard

echo "Updating Proxmox Helper Toolkit scripts..."

# Create a temporary directory and delete on exit
TEMP_DIR=$(mktemp -d)
trap 'rm -rf "$TEMP_DIR"' EXIT

# Ensure tracking file exists
touch "$TRACK_FILE"

# Get list of files in the repo root
files=$(curl -fsSL -H "Cache-Control: no-cache" "https://api.github.com/repos/$REPO/git/trees/$BRANCH?recursive=1" | grep -B2 '"type": "blob"' | grep -oP '"path":\s*"\K[^"]+')

for file in $files; do
    # Skip non-script files
    case "$file" in
        LICENSE|.gitignore|README.md)
            continue
            ;;
    esac

    echo "Downloading $file..."

    mkdir -p "$TEMP_DIR/$(dirname "$file")"
    curl -fsSL -H "Cache-Control: no-cache" "https://raw.githubusercontent.com/$REPO/$BRANCH/$file?nc=$(date +%s)" -o "$TEMP_DIR/$file"
    chmod +x "$TEMP_DIR/$file"

    case "$file" in
        */*) # Skip folders
            ;;
        *) # Track downloaded root scripts
            scripts_to_track["$file"]=1 # Track downloaded root scripts
            ;;
    esac

    # Set file status
    if [[ -f "$TARGET_DIR/$file" ]]; then
        if ! cmp -s "$TEMP_DIR/$file" "$TARGET_DIR/$file"; then
            file_status["$file"]="updated"

        else
            file_status["$file"]="same"
        fi

    else
        file_status["$file"]="new"
    fi
done

# Move files from temp directory to target
echo "Moving downloaded files to $TARGET_DIR"

cp -rf "$TEMP_DIR/"* "$TARGET_DIR/"

# Read currently tracked scripts
mapfile -t tracked_scripts < "$TRACK_FILE"

# Check for old scripts and remove them, also remove .pht if available
for removed_script in "${tracked_scripts[@]}"; do

    if [[ -z "${scripts_to_track[$removed_script]}" ]]; then
        if [ -f "$TARGET_DIR/$removed_script" ]; then

            file_status["$removed_script"]="removed"

            rm -f "$TARGET_DIR/$removed_script"
            rm -f "$PHT_DIR/$removed_script.pht"
        fi
    fi
done

# Update tracking file
printf "%s\n" "${!scripts_to_track[@]}" | sort > "$TRACK_FILE"

# Prepare file report
new_files=()
updated_files=()
removed_files=()

for file in "${!file_status[@]}"; do
    case "${file_status[$file]}" in
        new)
            new_files+=("$file")
            ;;
        updated)
            updated_files+=("$file")
            ;;
        removed)
            removed_files+=("$file")
            ;;
    esac
done

# Sort reports
[[ ${#new_files[@]} -gt 0 ]] && mapfile -t new_files < <(printf "%s\n" "${new_files[@]}" | sort)
[[ ${#updated_files[@]} -gt 0 ]] && mapfile -t updated_files < <(printf "%s\n" "${updated_files[@]}" | sort)
[[ ${#removed_files[@]} -gt 0 ]] && mapfile -t removed_files < <(printf "%s\n" "${removed_files[@]}" | sort)

# Report removed files
if [ "${#removed_files[@]}" -gt 0 ]; then
    echo "The following files got removed:"
    for script in "${removed_files[@]}"; do
        echo "  - $script"
    done
fi

# Report new files
if [ "${#new_files[@]}" -gt 0 ]; then
    echo "The following files were newly installed:"
    for script in "${new_files[@]}"; do
        echo "  - $script"
    done
fi

# Report updated files
if [ "${#updated_files[@]}" -gt 0 ]; then
    echo "The following files were updated:"
    for script in "${updated_files[@]}"; do
        echo "  - $script"
    done
fi

if [[ ${#new_files[@]} -eq 0 && ${#updated_files[@]} -eq 0 && ${#removed_files[@]} -eq 0 ]]; then
    echo "All files are already up-to-date"
fi

exit 0
