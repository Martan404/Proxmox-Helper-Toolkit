#!/usr/bin/env bash
# Install and update Proxmox Helper Toolkit
#v0002
TARGET_DIR="/usr/local/bin"
PHT_DIR="$TARGET_DIR/pht-files"
TRACK_FILE="$TARGET_DIR/.pht_scripts"

REPO="Martan404/Proxmox-Helper-Toolkit"
BRANCH="main"

declare -A repo_files
declare -A local_files
declare -A file_status
declare -A scripts_to_track

echo "Updating Proxmox Helper Toolkit scripts..."

TEMP_DIR=$(mktemp -d)
trap 'rm -rf "$TEMP_DIR"' EXIT

mkdir -p "$TARGET_DIR"
mkdir -p "$PHT_DIR"

touch "$TRACK_FILE"

#
# Download repository
#

echo "Downloading repository..."

curl -fsSL "https://github.com/$REPO/archive/refs/heads/$BRANCH.tar.gz" -o "$TEMP_DIR/repo.tar.gz"

mkdir "$TEMP_DIR/repo"

tar -xzf "$TEMP_DIR/repo.tar.gz" --strip-components=1 -C "$TEMP_DIR/repo"

#
# Remove unwanted repo files
#

rm -f "$TEMP_DIR/repo/LICENSE" "$TEMP_DIR/repo/README.md" "$TEMP_DIR/repo/.gitignore"

#
# Read repository files and compare
#

while IFS= read -r -d '' file; do

    relative="${file#"$TEMP_DIR/repo/"}"

    repo_files["$relative"]=1

    # Make root scripts executable and track them

    if [[ "$relative" != */* ]]; then

        case "$relative" in
            *.pht|*.bash)
                ;;
            *)
                chmod +x "$file"
                scripts_to_track["$relative"]=1
                ;;
        esac

    fi

    # Compare existing file

    if [[ -f "$TARGET_DIR/$relative" ]]; then

        if ! cmp -s "$file" "$TARGET_DIR/$relative"; then
            file_status["$relative"]="updated"
        fi

    else

        file_status["$relative"]="new"

    fi

done < <(find "$TEMP_DIR/repo" -type f -print0)

#
# Build list of installed toolkit files
#

# Root scripts

while IFS= read -r script; do

    [[ -n "$script" ]] &&
        local_files["$script"]=1

done < "$TRACK_FILE"

# pht-files directory

if [[ -d "$PHT_DIR" ]]; then

    while IFS= read -r -d '' file; do

        relative="${file#"$TARGET_DIR/"}"
        local_files["$relative"]=1

    done < <(find "$PHT_DIR" -type f -print0)

fi

#
# Remove files no longer in repository
#

for old_file in "${!local_files[@]}"; do

    if [[ -z "${repo_files[$old_file]}" ]]; then

        if [[ -f "$TARGET_DIR/$old_file" ]]; then

            echo "Removing $old_file"

            file_status["$old_file"]="removed"

            rm -f "$TARGET_DIR/$old_file"

        fi

    fi

done

#
# Install files
#

echo "Installing files..."


while IFS= read -r -d '' file; do

    relative="${file#"$TEMP_DIR/repo/"}"

    mkdir -p "$TARGET_DIR/$(dirname "$relative")"

    #
    # Special handling for updater:
    # copy last so the running updater survives
    #

    if [[ "$relative" == "pht-updater" ]]; then
        continue
    fi


    cp -f "$file" "$TARGET_DIR/$relative"

done < <(find "$TEMP_DIR/repo" -type f -print0)

#
# Update tracker
#

printf "%s\n" "${!scripts_to_track[@]}" | sort > "$TRACK_FILE"

#
# Replace updater last
#

if [[ -f "$TEMP_DIR/repo/pht-updater" ]]; then

    cp -f \
        "$TEMP_DIR/repo/pht-updater" \
        "$TARGET_DIR/pht-updater"

    chmod +x "$TARGET_DIR/pht-updater"

fi

#
# Build reports
#

new_files=()
updated_files=()
removed_files=()


for file in "${!file_status[@]}"; do

    case "${file_status[$file]}" in

        new)
            new_files+=("$file")
            ;;

        updated)
            updated_files+=("$file")
            ;;

        removed)
            removed_files+=("$file")
            ;;

    esac

done

#
# Sort reports
#

[[ ${#new_files[@]} -gt 0 ]] &&
mapfile -t new_files < <(printf "%s\n" "${new_files[@]}" | sort)


[[ ${#updated_files[@]} -gt 0 ]] &&
mapfile -t updated_files < <(printf "%s\n" "${updated_files[@]}" | sort)


[[ ${#removed_files[@]} -gt 0 ]] &&
mapfile -t removed_files < <(printf "%s\n" "${removed_files[@]}" | sort)

#
# Report
#

if [[ ${#removed_files[@]} -gt 0 ]]; then

    echo
    echo "The following files were removed:"

    for file in "${removed_files[@]}"; do
        echo "  - $file"
    done

fi


if [[ ${#new_files[@]} -gt 0 ]]; then

    echo
    echo "The following files were newly installed:"

    for file in "${new_files[@]}"; do
        echo "  - $file"
    done

fi


if [[ ${#updated_files[@]} -gt 0 ]]; then

    echo
    echo "The following files were updated:"

    for file in "${updated_files[@]}"; do
        echo "  - $file"
    done

fi

if [[ ${#new_files[@]} -eq 0 &&
      ${#updated_files[@]} -eq 0 &&
      ${#removed_files[@]} -eq 0 ]]; then

    echo "All files are already up-to-date"

fi

echo
echo "Done! All files are updated"
