#!/bin/bash
# Mount/unmount network drives via NFS and Samba

# Dependencies
# apt install -y nfs-common cifs-utils

# Global constants
SCRIPT_NAME="$(basename "$0")"
MOUNT_PATH="/mnt/nas"
MOUNT_FILE="$MOUNT_PATH/.network_mounts"

USAGE="Usage:
  $SCRIPT_NAME status
  $SCRIPT_NAME mount-nfs <server-ip> <share-path> <local-name>
  $SCRIPT_NAME mount-smb <server-ip> <share-path> <local-name>
  $SCRIPT_NAME unmount <local-name>"

mkdir -p "$MOUNT_PATH"
touch "$MOUNT_FILE"

# Helper: print error and exit
error_exit() {
    echo "Error: $1" >&2
    exit 1
}

[[ $EUID -ne 0 ]] && error_exit "Run as root."

mount_nfs() {
    local nfs_ip="$1"
    local nfs_path="$2"
    local local_name="$3"

    [[ -z "$nfs_ip" || -z "$nfs_path" || -z "$local_name" ]] &&
        error_exit "Usage: $SCRIPT_NAME mount-nfs <server-ip> <share-path> <local-name>"

    local nfs_full_path="$nfs_ip:$nfs_path"
    local target="$MOUNT_PATH/$local_name"

    mkdir -p "$target"
    mountpoint -q "$target" && error_exit "$target is already mounted."

    if mount -t nfs -o rw,vers=4 "$nfs_full_path" "$target"; then
        grep -Fxq "nfs $nfs_full_path $local_name" "$MOUNT_FILE" || echo "nfs $nfs_full_path $local_name" >> "$MOUNT_FILE"

        fstab_entry="$nfs_full_path $target nfs defaults,user,noauto,_netdev 0 0"
        grep -Fxq "$fstab_entry" /etc/fstab || echo "$fstab_entry" >> /etc/fstab

        echo "Mounted $nfs_full_path at $target"
    else
        error_exit "Failed to mount $nfs_full_path"
    fi
}

mount_smb() {
    local smb_ip="$1"
    local smb_path="$2"
    local local_name="$3"

    [[ -z "$smb_ip" || -z "$smb_path" || -z "$local_name" ]] &&
        error_exit "Usage: $SCRIPT_NAME mount-smb <server-ip> <share-path> <local-name>"

    local smb_full_path="//$smb_ip$smb_path"
    local target="$MOUNT_PATH/$local_name"

    mkdir -p "$target"
    mountpoint -q "$target" && error_exit "$target is already mounted."


    if mount -t cifs -o rw,vers=3.0,guest "$smb_full_path" "$target"; then
        grep -Fxq "cifs $smb_full_path $local_name" "$MOUNT_FILE" || echo "cifs $smb_full_path $local_name" >> "$MOUNT_FILE"

        fstab_entry="$smb_full_path $target cifs rw,vers=3.0,guest,noauto,_netdev 0 0"
        grep -Fxq "$fstab_entry" /etc/fstab || echo "$fstab_entry" >> /etc/fstab

        echo "Mounted $smb_full_path at $target"
    else
        error_exit "Failed to mount $smb_full_path"
    fi
}

unmount_nas() {
    local local_name="$1"

    [[ -z "$local_name" ]] &&
        error_exit "Usage: $SCRIPT_NAME unmount <local-name>"

    [[ -f "$MOUNT_FILE" ]] || error_exit "No mount database found."

    entry=$(awk -v name="$local_name" '$3==name {print}' "$MOUNT_FILE")

    [[ -z "$entry" ]] && error_exit "No mount named '$local_name'."

    mount_point="$MOUNT_PATH/$local_name"

    umount "$mount_point" || error_exit "Failed to unmount $mount_point"

    grep -Fxv "$entry" "$MOUNT_FILE" > "$MOUNT_FILE.tmp" && mv "$MOUNT_FILE.tmp" "$MOUNT_FILE"

    echo "Unmounted $local_name"

    echo "Removing fstab entry"
    awk -v mp="$mount_point" '/^[[:space:]]*#/ || NF==0 { print; next } $2 != mp { print }' /etc/fstab > /etc/fstab.tmp && mv /etc/fstab.tmp /etc/fstab
}

status_nas() {
    awk '$2 ~ "^'"$MOUNT_PATH"'" { printf "%-35s %-30s (%s)\n",$1,$2,$3 }' /proc/mounts

    if [[ ${PIPESTATUS[0]} -ne 0 ]]; then
        echo "No NAS drives mounted."
    fi
}

case "$1" in
    mount-nfs)
        shift
        mount_nfs "$@"
        ;;
    mount-smb)
        shift
        mount_smb "$@"
        ;;
    unmount)
        shift
        unmount_nas "$@"
        ;;
    status)
        status_nas
        ;;
    *)
        error_exit "$USAGE"
        ;;
esac
