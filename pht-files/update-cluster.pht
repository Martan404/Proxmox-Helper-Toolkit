title = "Update Cluster"
description = "Updates containers and packages across the Proxmox cluster"

[action]
name = "Update Cluster"
command = "update-cluster"
arguments = ""
default=true

[flag]
name = "Update nodes in parallel"
arguments = "--parallel"
[/flag]

[confirm]
message = "Update the entire cluster?"
[/confirm]

[/action]
