title = "Mount Folder To Container"
description = "Adds a folder as an LXC mount point"

[action]
name = "Add Mount Point"
command = "mount-to-container"
arguments = ""
default=true

[field]
name = "Container ID (100)"
type = "number"
[/field]

[field]
name = "Host Mount Path (/mnt/usb/Share)"
type = "path"
[/field]

[field]
name = "Container Mount Path (/mnt/lan/Share)"
type = "path"
[/field]

[/action]
