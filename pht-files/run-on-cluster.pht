title = "Run On Cluster"
description = "Runs a command on every Proxmox node"

[action]
name = "Run Command"
command = "run-on-cluster"
arguments = ""
default=true

[flag]
name = "Run in parallel"
arguments = "--parallel"
[/flag]

[field]
name = "Command to execute"
type = "input"
[/field]

[/action]
