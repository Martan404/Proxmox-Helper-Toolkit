title = "Run On Cluster"
description = "Runs a command on every Proxmox node"


[action]
name = "Run Command"
command = ""
default=true

[flag]
name = "parallel"
label = "Run in parallel"
argument = "--parallel"
[/flag]

[field]
name = "command"
label = "Command to execute"
type = "input"
[/field]

[/action]
