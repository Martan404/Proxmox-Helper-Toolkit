#!/bin/bash
# Updates the entire Proxmox cluster

# shellcheck disable=SC2016

PARALLEL=false

# Parse optional flag
if [[ "$1" == "--parallel" || "$1" == "-p" ]]; then
    PARALLEL=true
    shift
fi

if [ $# -gt 0 ]; then
    echo "Usage: $0 [--parallel|-p]"
    exit 1
fi

run_on_cluster() {
    if [ "$PARALLEL" = true ]; then
        run-on-cluster -p "$1"
    else
        run-on-cluster "$1"
    fi
}

echo "Updating apps on all running containers across the cluster..."
echo

run_on_cluster 'var_backup=no var_container=all_running var_unattended=yes var_skip_confirm=yes var_auto_reboot=yes bash -c "$(curl -fsSL https://raw.githubusercontent.com/community-scripts/ProxmoxVE/main/tools/pve/update-apps.sh)"'
echo

echo "Updating system packages across the cluster..."
echo

run_on_cluster 'apt --assume-yes update && apt --assume-yes upgrade'
echo

echo "Cluster update complete."
echo

# Ask for reboot
read -rp "Do you want to reboot all servers in the cluster? (y/N): " answer

case "$answer" in
    [yY]|[yY][eE][sS])
        echo "Rebooting all servers..."
        run_on_cluster 'reboot'
        ;;
    *)
        echo "Skipping reboot."
        ;;
esac