#!/bin/bash
# Updates the entire Proxmox cluster

# shellcheck disable=SC2016

echo "Updating apps on all running containers across the cluster..."
echo

run-on-cluster 'var_backup=no var_container=all_running var_unattended=yes var_skip_confirm=yes var_auto_reboot=yes bash -c "$(curl -fsSL https://raw.githubusercontent.com/community-scripts/ProxmoxVE/main/tools/pve/update-apps.sh)"'
echo

echo "Updating system packges across the cluster..."
echo

run-on-cluster 'apt --assume-yes update && apt --assume-yes upgrade'
echo

echo "Cluster update complete."
echo

# Ask for reboot
read -rp "Do you want to reboot all servers in the cluster? (y/N): " answer

case "$answer" in
    [yY]|[yY][eE][sS])
        echo "Rebooting all servers..."
        run-on-cluster 'reboot'
        ;;
    *)
        echo "Skipping reboot."
        ;;
esac