#!/bin/bash
# Runs <command> on every Proxmox node in the cluster, optionally in parallel

PARALLEL=false

# Parse optional flag
if [[ "$1" == "--parallel" || "$1" == "-p" ]]; then
    PARALLEL=true
    shift
fi

if [ $# -eq 0 ]; then
    echo "Usage: $0 [--parallel|-p] <command>"
    exit 1
fi

COMMAND="$*"
CURRENT_NODE=$(hostname)

# Grab node names from the cluster
NODES=$(pvecm nodes | awk '/Nodeid/{flag=1; next} flag && NF>=3 {print $3}')

run_command() {
    local NODE="$1"

    echo "[ $NODE ]"

    # Get the node's IP from vmbr0
    NODE_IP=$(pvesh get /nodes/$NODE/network --output-format json | jq -r '.[] | select(.iface=="vmbr0") | .address' | cut -d/ -f1)

    if [[ -z "$NODE_IP" ]]; then
        echo -e "[ WARNING ] Could not determine IP for $NODE, skipping."
        return
    fi

    if [[ "$NODE" == "$CURRENT_NODE" ]]; then
        bash -c "$COMMAND"
    else
        ssh -o BatchMode=yes -o ConnectTimeout=5 -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null root@"$NODE_IP" "export TERM=xterm; $COMMAND" 2>/dev/null
        SSH_EXIT=$?
        if [[ $SSH_EXIT -ne 0 ]]; then
            echo -e "[ WARNING ] SSH to $NODE ($NODE_IP) failed with exit code $SSH_EXIT"
        fi
    fi
    echo
}

for NODE in $NODES; do
    if $PARALLEL; then
        run_command "$NODE" &
    else
        run_command "$NODE"
    fi
done

# Wait for all background jobs if parallel
if $PARALLEL; then
    wait
fi