title = "Mount Folder To Container"
description = "Adds a folder as an LXC mount point"


[action]
name = "Add Mount Point"
command = ""

[field]
name = "ctid"
label = "Container ID"
type = "number"
[/field]

[field]
name = "mountpoint"
label = "Host Mount Path"
type = "path"
[/field]

[field]
name = "local_mount"
label = "Container Mount Path"
type = "path"
[/field]

[/action]
